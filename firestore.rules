rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /connections/{connId} {
      allow read, write: if request.auth != null 
                         && (resource.data.clientId == request.auth.uid
                             || (!exists(/databases/$(database)/documents/connections/$(connId)) && request.auth.uid != null));
    }

    match /contacts/{contactId} {
      allow read, write: if request.auth != null 
                         && (resource.data.clientId == request.auth.uid
                             || (!exists(/databases/$(database)/documents/contacts/$(contactId)) && request.auth.uid != null));
    }

    match /messages/{msgId} {
      allow read, write: if request.auth != null 
                         && (resource.data.clientId == request.auth.uid
                             || (!exists(/databases/$(database)/documents/messages/$(msgId)) && request.auth.uid != null));
    }
  }
}